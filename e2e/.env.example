# Copy to e2e/.env for local runs. e2e/.env is ignored by git.

# Local default. Authenticated tests must use an HTTPS *.gainforest.app URL.
E2E_BASE_URL=https://local-e2e.gainforest.app
E2E_PORT=3201

# Required test account. Keep the password in e2e/.env or your shell, not in source control.
E2E_TEST_HANDLE=satyam-test.climateai.org
E2E_TEST_PASSWORD=
E2E_TEST_PDS_DOMAIN=climateai.org

# Optional: run against an already-started app or a preview URL.
# E2E_SKIP_WEB_SERVER=1
# VERCEL_BYPASS_SECRET=
